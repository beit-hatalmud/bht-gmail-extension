{
  "manifest_version": 3,
  "name": "מעקב התנהגות - בית התלמוד",
  "version": "1.0.0",
  "description": "תוסף צף ל-Gmail לניהול מעקב התנהגות, חתימות הורים ומשימות מתוך הדואר.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://script.google.com/*",
    "https://beit-hatalmud.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "מעקב התנהגות - בית התלמוד",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["floating.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
